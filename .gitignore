# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg

# Environment
.env
*.env.local

# Language state (set by setup.sh --lang)
.claude/.current-lang

# Claude Code local settings (contains MCP server permissions, may contain API keys)
.claude/settings.local.json

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Virtual environment
.venv/

# ---------------------------------------------------------------------------
# Per-user data — NEVER commit, NEVER push to upstream.
#
# Origin's wiki/{papers,concepts,...}/ and raw/* contain only .gitkeep
# placeholders; the actual content is generated locally by /init, /ingest,
# /exp-run, etc. Each user's wiki is theirs; pushing it back pollutes the
# template repo. Rules below ignore content but keep the .gitkeep scaffolds.
# ---------------------------------------------------------------------------

# User-owned raw inputs (excluding scaffolds)
raw/papers/*
!raw/papers/.gitkeep
raw/notes/*
!raw/notes/.gitkeep
raw/web/*
!raw/web/.gitkeep
raw/discovered/*
!raw/discovered/.gitkeep
raw/tmp/*
!raw/tmp/.gitkeep

# Wiki entity content (excluding scaffolds)
wiki/papers/*
!wiki/papers/.gitkeep
wiki/concepts/*
!wiki/concepts/.gitkeep
wiki/topics/*
!wiki/topics/.gitkeep
wiki/people/*
!wiki/people/.gitkeep
wiki/ideas/*
!wiki/ideas/.gitkeep
wiki/experiments/*
!wiki/experiments/.gitkeep
wiki/methods/*
!wiki/methods/.gitkeep
wiki/Summary/*
!wiki/Summary/.gitkeep
wiki/foundations/*
!wiki/foundations/.gitkeep
wiki/outputs/*
!wiki/outputs/.gitkeep

# Wiki graph derived state (auto-generated by tools/research_wiki.py)
wiki/graph/*
!wiki/graph/.gitkeep

# Note: wiki/index.md and wiki/log.md ARE tracked upstream as empty
# baselines. Don't add them to .gitignore (gitignore can't untrack).
# Treat any local content beyond the upstream baseline as user-data:
# don't `git add` modifications to either file.

# ---------------------------------------------------------------------------
# Skill-generated runtime state (regenerated each invocation)
# ---------------------------------------------------------------------------

# /init session state
.checkpoints/
wiki/.checkpoints/

# /exp-run generated experiment code
experiments/code/

# /visualize generated artifacts (regenerated from config/visualize.json
# + wiki/graph/ at /init Step 6 or direct /visualize)
wiki/.obsidian/
wiki/canvases/
wiki/graph-view.html

# ---------------------------------------------------------------------------
# Local IDE / editor state
# ---------------------------------------------------------------------------
.obsidian/
.claude/scheduled_tasks.lock

# Obsidian "untitled canvas" debris (locale-aware: en + zh)
**/Untitled*.canvas
**/未命名*.canvas